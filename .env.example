APP_ENV=local
APP_DEBUG=false
APP_NAME="NeNe Invoice"
PROBLEM_DETAILS_BASE_URL=https://nene-invoice.dev/problems/

# --- Install location (ADR 0015) ---
# 通常は空でよい。設置パス（root / サブディレクトリ）は SCRIPT_NAME から自動検出される。
# リバースプロキシ等で自動検出が効かない場合のみ、例: APP_BASE_PATH=/invoice を指定する。
APP_BASE_PATH=

# --- Tenancy (ADR 0006) — default single-organization install ---
TENANT_RESOLUTION=single
ORG_SLUG=
BASE_DOMAIN=localhost

# --- Disposable-demo mode (税理士リード向けデモ・使い捨て org / NENE2 `Nene2\Demo`) ---
# 1 にすると公開ルート `GET /demo/{template}`（template ∈ kensetsu|bldmainte|seisaku）が
# 有効になり、都度ランダム slug の使い捨て org を生成・業種シード投入・セッション発行して
# `/{slug}/dashboard` へ 302 する。**デモ機専用**。本番・通常インストールでは未設定(=無効)のままにする。
# 前提: `TENANT_RESOLUTION=path`（single だと soleOrgFallback で全員同一 org に落ちる）＋ HTTPS
# （Cookie は Secure 固定。localhost は secure 扱い）。使い捨て org の掃除は tools/sweep-demo.php を cron で。
# 乱用対策（#608/#612）: 作成前に per-IP スロットル（30回/時・429）と org 数上限（503）をチェックする。
# 判定状態は var/rate-limits/ のファイル（共有ホスティングでもプロセス跨ぎで効く）。
# ブラウザ（Accept: text/html）には裸の JSON でなく日本語の説明ページを返す（#612）。
# 値は NENE2 ConfigLoader が厳格にパースする（DEMO_MODE は 1/true/yes のみ有効＝fail-close）。
# DEMO_MODE=1
# DEMO_SLUG_PREFIX=demo-   # 使い捨て org の slug 接頭辞。sweep と上限カウントの境界
# DEMO_TTL_HOURS=3         # 作成から何時間で sweep 対象になるか
# DEMO_MAX_ORGS=200        # 同時に存在できる demo org の上限（超過分は古い順に sweep・作成は 503）
# DEMO_SLUG_ATTEMPTS=5     # slug 衝突時のリトライ回数
#
# デモ限定 cookieless 計測（GoatCounter 自己ホスト・#658）。**デモ機の .env にのみ**
# 計測ホストの origin を設定すると、SPAシェルに GoatCounter ビーコンを注入し、その応答の
# CSP に当該 origin を追加する（script-src / connect-src / img-src）。**未設定なら一切注入せず
# CSP も既定のまま**＝OSS 本体・通常インストールは計測ゼロ。origin 文字列はこの .env.example や
# コミット済みフロント（React ビルド）・.htaccess には**焼き込まない**（信頼の柱）。
# 例: DEMO_ANALYTICS_ENDPOINT=https://stats.example.test （末尾スラッシュ無し・パス無しの origin）
# DEMO_ANALYTICS_ENDPOINT=

# --- Recurring billing execution (#526) ---
# 1（既定）: 共用ホスティング(Tier A・cron 不可)向け。認証済み /admin/ リクエスト時に
#   期日到来の定期請求の「下書き」を自動生成する（組織ごと 1日1回にスロットル）。
# 0: cron(Tier B)で `php tools/run-recurring.php` を回す運用にする場合に無効化する。
# いずれも生成するのは下書きのみ（発行・採番は税理士確認を要する別工程）。
RECURRING_INLINE=1

# --- Auth: HMAC secret for bearer tokens (operator + service tokens) ---
# 本番(APP_ENV=production)では必須。未設定だと起動を拒否します（既知の既定値へ
# フォールバックしません）。インストーラは自動生成します。手動設定する場合:
#   php -r "echo bin2hex(random_bytes(32));"
NENE2_LOCAL_JWT_SECRET=

# local/dev のみ: 1 にすると NENE2_LOCAL_JWT_SECRET 未設定時にフレームワーク組込みの
# 開発用シークレットで起動できる（利便性のための opt-in）。本番では無視されます
# （未設定なら secret 必須のまま fail-closed）。
NENE2_ALLOW_DEV_SECRET=

# --- Card payment gateway: PAY.JP (ADR 0013) ---
# テストキーはダッシュボードで審査なしに取得可。本番キー(sk_live_)は審査後。
# 値は秘匿（.env に置き、コミットしない）。
PAYJP_SECRET_KEY=
PAYJP_PUBLIC_KEY=
# webhook エンドポイント登録時に発行される whook_ トークン（#431 で使用）。
PAYJP_WEBHOOK_TOKEN=

# --- Database (host / PHPUnit default: SQLite) ---
# DB_ADAPTER: sqlite | mysql | pgsql （3アダプタ対応 — repository SQL は方言非依存）
DB_ADAPTER=sqlite
DB_NAME=var/nene_invoice.sqlite
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=nene_invoice
DB_PASSWORD=
DB_CHARSET=utf8mb4

# --- Mail (SMTP) ---
# ホスト直実行: docker compose up -d mailpit → ホスト側は 127.0.0.1:1585 に送信。
#   受信確認 http://localhost:8585
# Docker スタック: コンテナ間は mailpit:1025（compose.yaml が自動設定するため変更不要）
# 本番: 実際の SMTP サーバー情報に変更してください
MAIL_HOST=127.0.0.1
MAIL_PORT=1585
MAIL_FROM_ADDRESS=invoice@example.com
MAIL_FROM_NAME="NeNe Invoice"
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=

# --- Docker Compose（ホスト直実行では不要。`docker compose up` 用の上書き）---
# compose.yaml が下記の既定値を内蔵しているため通常は設定不要。ポートや DB 認証情報を
# 変えたい場合のみ .env で上書きする。
# DB_ADAPTER=mysql
# DB_HOST=mysql
# DB_PORT=3306
# DB_NAME=nene_invoice
# DB_USER=nene_invoice
# DB_PASSWORD=nene_invoice
# MYSQL_ROOT_PASSWORD=nene_invoice_root
#
# ポート（CLAUDE.md の 85** レンジ規約に従う）
# NENE_INVOICE_PORT=8510            # app（Apache, API + 管理 UI）
# NENE_INVOICE_MYSQL_PORT=3585      # MySQL
# NENE_INVOICE_PHPMYADMIN_PORT=8581 # phpMyAdmin
# NENE_INVOICE_MAILPIT_SMTP_PORT=1585
# NENE_INVOICE_MAILPIT_WEB_PORT=8585
#
# INVOICE_SEED_DEV=1   # 0 で dev ダミーデータ投入を無効化（本番相当確認用）
