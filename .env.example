APP_ENV=local
APP_DEBUG=false
APP_NAME="NeNe Invoice"
PROBLEM_DETAILS_BASE_URL=https://nene-invoice.dev/problems/

# --- Tenancy (ADR 0006) — default single-organization install ---
TENANT_RESOLUTION=single
ORG_SLUG=
BASE_DOMAIN=localhost

# --- Auth: HMAC secret for local bearer tokens (set a strong random value in production) ---
NENE2_LOCAL_JWT_SECRET=

# --- Database (host / PHPUnit default: SQLite) ---
DB_ADAPTER=sqlite
DB_NAME=var/nene_invoice.sqlite
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=nene_invoice
DB_PASSWORD=
DB_CHARSET=utf8mb4

# --- Mail (SMTP) — docker compose up でローカル Mailpit を起動 ---
# 開発: docker compose up -d mailpit → http://localhost:8025 で受信確認
# 本番: 実際の SMTP サーバー情報に変更してください
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_FROM_ADDRESS=invoice@example.com
MAIL_FROM_NAME="NeNe Invoice"
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=
