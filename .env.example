APP_ENV=local
APP_DEBUG=false
APP_NAME="NeNe Invoice"
PROBLEM_DETAILS_BASE_URL=https://nene-invoice.dev/problems/

# --- Tenancy (ADR 0006) — default single-organization install ---
TENANT_RESOLUTION=single
ORG_SLUG=
BASE_DOMAIN=localhost

# --- Auth: HMAC secret for bearer tokens (operator + service tokens) ---
# 本番(APP_ENV=production)では必須。未設定だと起動を拒否します（既知の既定値へ
# フォールバックしません）。インストーラは自動生成します。手動設定する場合:
#   php -r "echo bin2hex(random_bytes(32));"
NENE2_LOCAL_JWT_SECRET=

# --- Database (host / PHPUnit default: SQLite) ---
# DB_ADAPTER: sqlite | mysql | pgsql （3アダプタ対応 — repository SQL は方言非依存）
DB_ADAPTER=sqlite
DB_NAME=var/nene_invoice.sqlite
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=nene_invoice
DB_PASSWORD=
DB_CHARSET=utf8mb4

# --- Mail (SMTP) ---
# ホスト直実行: docker compose up -d mailpit → ホスト側は 127.0.0.1:1585 に送信。
#   受信確認 http://localhost:8585
# Docker スタック: コンテナ間は mailpit:1025（compose.yaml が自動設定するため変更不要）
# 本番: 実際の SMTP サーバー情報に変更してください
MAIL_HOST=127.0.0.1
MAIL_PORT=1585
MAIL_FROM_ADDRESS=invoice@example.com
MAIL_FROM_NAME="NeNe Invoice"
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=

# --- Docker Compose（ホスト直実行では不要。`docker compose up` 用の上書き）---
# compose.yaml が下記の既定値を内蔵しているため通常は設定不要。ポートや DB 認証情報を
# 変えたい場合のみ .env で上書きする。
# DB_ADAPTER=mysql
# DB_HOST=mysql
# DB_PORT=3306
# DB_NAME=nene_invoice
# DB_USER=nene_invoice
# DB_PASSWORD=nene_invoice
# MYSQL_ROOT_PASSWORD=nene_invoice_root
#
# ポート（CLAUDE.md の 85** レンジ規約に従う）
# NENE_INVOICE_PORT=8510            # app（Apache, API + 管理 UI）
# NENE_INVOICE_MYSQL_PORT=3585      # MySQL
# NENE_INVOICE_PHPMYADMIN_PORT=8581 # phpMyAdmin
# NENE_INVOICE_MAILPIT_SMTP_PORT=1585
# NENE_INVOICE_MAILPIT_WEB_PORT=8585
#
# INVOICE_SEED_DEV=1   # 0 で dev ダミーデータ投入を無効化（本番相当確認用）
