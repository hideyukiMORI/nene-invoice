{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "project": ["src/**/*.{ts,tsx}", "tests/**/*.{ts,tsx}", "e2e/**/*.ts"],
  "entry": ["e2e/**/*.spec.ts"],
  "ignoreDependencies": ["tailwindcss"],
  "ignoreExportsUsedInFile": true,
  "ignoreIssues": {
    "src/shared/api/schema.gen.ts": ["exports", "types"]
  },
  "tags": ["-knipignore"]
}
