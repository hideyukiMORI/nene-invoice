{
    "name": "hideyukimori/nene-invoice",
    "description": "NeNe Invoice — self-hosted, multi-tenant quote, invoice, and payment platform on NENE2.",
    "type": "project",
    "license": "MIT",
    "repositories": [
        {
            "//": "S2 dev only (#562) — link local NENE2 for the Nene2\\Install toolkit before its 1.6.0 release. MUST be reverted (back to Packagist ^1.6) before merge.",
            "type": "path",
            "url": "../NENE2",
            "options": {
                "symlink": true
            }
        }
    ],
    "require": {
        "php": ">=8.4.1 <9.0",
        "hideyukimori/nene2": "dev-main as 1.6.0",
        "mpdf/mpdf": "^8.3",
        "phpmailer/phpmailer": "^7.1"
    },
    "autoload": {
        "psr-4": {
            "NeneInvoice\\": "src/"
        },
        "files": [
            "src/bootstrap.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "NeneInvoice\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit --testsuite NeneInvoice",
        "test:integration": "phpunit --testsuite integration",
        "analyse": "phpstan analyse --memory-limit 512M",
        "cs": "php-cs-fixer fix --dry-run --diff --config=.php-cs-fixer.php",
        "cs:fix": "php-cs-fixer fix --config=.php-cs-fixer.php",
        "migrations:status": "phinx status -c phinx.php",
        "migrations:migrate": "phinx migrate -c phinx.php",
        "migrations:rollback": "phinx rollback -c phinx.php",
        "openapi": "php tools/validate-openapi.php",
        "mcp": "php vendor/hideyukimori/nene2/tools/validate-mcp-tools.php --root=.",
        "mcp:generate": "php tools/generate-mcp-tools.php",
        "check": [
            "@test",
            "@analyse",
            "@cs",
            "@openapi",
            "@mcp"
        ]
    },
    "config": {
        "sort-packages": true
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.95",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^13.1",
        "robmorgan/phinx": "^0.16.11",
        "symfony/yaml": "^8.1"
    }
}
